{
  "expo": {
    "name": "garden-hacks-mobile",
    "slug": "garden-hacks-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "gardenhacksmobile",
    "userInterfaceStyle": "light",
    "ios": {},
    "android": {
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f7faf5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
